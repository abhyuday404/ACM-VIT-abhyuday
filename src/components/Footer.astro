---
// Footer.astro
import { getAssetUrl } from "../utils/cdn";

const footerBackgroundSrc = getAssetUrl("/footer/footer-background.webp");
const footerForegroundSrc = getAssetUrl("/footer/footer-foreground-new.png");
---

<div data-variant-host>
  <template data-variant="desktop">
    <footer
      id="footer"
      class="relative w-full overflow-hidden m-0 p-0 flex flex-col"
    >
      <div
        class="hidden md:block w-full max-w-[1438px] h-0 outline outline-1 outline-offset-[-0.50px] outline-white mx-auto"
      >
      </div>

      <div class="relative z-10 hidden md:flex flex-col min-h-[50vh] pb-8">
        <div
          class="flex-grow flex flex-col lg:flex-row items-start gap-10 lg:gap-0 justify-between px-6 lg:px-16 pt-6"
        >
          <div class="flex-shrink-0 w-full lg:w-auto mr-8">
            <div
              class="text-yellow-50 text-xl font-bold font-['PolySans_Trial'] leading-tight"
              style="font-family: 'PolySans Bold', 'PolySans Trial', sans-serif;"
            >
              association for<br />computing machinery
            </div>
            <div
              class="w-fit my-4 relative flex items-center border border-zinc-100 rounded-full px-6 py-1.5 pr-8"
            >
              <!-- glowign dot -->
              <div
                class="w-3 h-3 bg-green-500 rounded-full shadow-[0_0_8px_2px_rgba(34,197,94,0.6)]
            animate-[pulse_1.5s_ease-in-out_infinite]"
