<script>
  const STAR_COLOR = "#fff";
  const STAR_SIZE = 1.5;
  const STAR_MIN_SCALE = 0.2;
  const OVERFLOW_THRESHOLD = 50;
  const SHOOTING_STAR_PERIOD = 420;
  const MIN_ACTIVE_SHOOTING_STARS = 2;
  const MAX_ACTIVE_SHOOTING_STARS = 5;

  type FooterStar = {
    x: number;
    y: number;
    z: number;
  };

  type FooterShootingStar = {
    x: number;
    y: number;
    vx: number;
    vy: number;
    life: number;
    ttl: number;
    length: number;
    width: number;
  };

  const initFooterStarCanvas = (canvas: HTMLCanvasElement) => {
    if (canvas.dataset.footerStarInit === "true") return;
    canvas.dataset.footerStarInit = "true";

    const context = canvas.getContext("2d");
    const host = canvas.closest(".footer-star-art") as HTMLElement | null;
    if (!context || !host) return;

    let scale = 1;
    let width = 0;
    let height = 0;
    let rafId = 0;
    let lastFrameTime = 0;
    let lastShooterAt = 0;
    let isVisible = false;
    let isReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    let pointerX: number | null = null;
    let pointerY: number | null = null;
    let touchInput = false;

    const velocity = { x: 0, y: 0, tx: -0.65, ty: 0.24, z: 0.0005 };
    const stars: FooterStar[] = [];
    const shootingStars: FooterShootingStar[] = [];

    const getStarCount = () => {
      const viewportWidth = window.innerWidth;
      const densityMultiplier =
        viewportWidth <= 640 ? 2 : viewportWidth <= 1024 ? 1.5 : 1;
      const base = Math.max(
        90,
        Math.min(260, Math.round((width + height) / (8 * scale))),
      );
      return Math.round(base * densityMultiplier);
    };

    const placeStar = (star: FooterStar) => {
      star.x = Math.random() * width;
      star.y = Math.random() * height;
    };

    const generateStars = () => {
      const nextCount = getStarCount();
      while (stars.length < nextCount) {
        const star = {
          x: 0,
          y: 0,
          z: STAR_MIN_SCALE + Math.random() * (1 - STAR_MIN_SCALE),
        };
        placeStar(star);
        stars.push(star);
      }
      if (stars.length > nextCount) stars.length = nextCount;
    };

    const recycleStar = (star: FooterStar) => {
      let direction = "z";
      const vx = Math.abs(velocity.x);
      const vy = Math.abs(velocity.y);

      if (vx > 1 || vy > 1) {
        const axis =
          vx > vy
            ? Math.random() < vx / (vx + vy)
              ? "h"
              : "v"
            : Math.random() < vy / (vx + vy)
              ? "v"
              : "h";

        if (axis === "h") {
          direction = velocity.x > 0 ? "l" : "r";
        } else {
          direction = velocity.y > 0 ? "t" : "b";
        }
      }

      star.z = STAR_MIN_SCALE + Math.random() * (1 - STAR_MIN_SCALE);

      if (direction === "z") {
        star.z = 0.1;
        star.x = Math.random() * width;
        star.y = Math.random() * height;
      } else if (direction === "l") {
        star.x = -OVERFLOW_THRESHOLD;
        star.y = height * Math.random();
      } else if (direction === "r") {
        star.x = width + OVERFLOW_THRESHOLD;
        star.y = height * Math.random();
      } else if (direction === "t") {
        star.x = width * Math.random();
        star.y = -OVERFLOW_THRESHOLD;
      } else if (direction === "b") {
        star.x = width * Math.random();
        star.y = height + OVERFLOW_THRESHOLD;
      }
    };

    const resize = () => {
      const rect = host.getBoundingClientRect();
      if (!rect.width || !rect.height) return;

      scale = Math.min(window.devicePixelRatio || 1, 2);
      width = Math.round(rect.width * scale);
      height = Math.round(rect.height * scale);
      canvas.width = width;
      canvas.height = height;

      generateStars();
      stars.forEach(placeStar);
    };

    const getShootingDirection = () => {
      const speed = Math.hypot(velocity.x, velocity.y);
      if (speed > 0.35) {
        return {
          x: velocity.x / speed,
          y: velocity.y / speed,
        };
      }
      return { x: -0.92, y: 0.38 };
    };

    const spawnShootingStar = () => {
      if (
        !width ||
        !height ||
        shootingStars.length >= MAX_ACTIVE_SHOOTING_STARS
      )
        return;

      const direction = getShootingDirection();
      const speed = (16 + Math.random() * 8) * scale;
      const fromHorizontalEdge = Math.abs(direction.x) >= Math.abs(direction.y);
      let x = 0;
      let y = 0;

      if (fromHorizontalEdge) {
        x =
          direction.x > 0
            ? -OVERFLOW_THRESHOLD * scale
            : width + OVERFLOW_THRESHOLD * scale;
        y = height * (0.08 + Math.random() * 0.34);
      } else {
        x = width * (0.45 + Math.random() * 0.45);
        y =
          direction.y > 0
            ? -OVERFLOW_THRESHOLD * scale
            : height + OVERFLOW_THRESHOLD * scale;
      }

      shootingStars.push({
        x,
        y,
        vx: direction.x * speed,
        vy: direction.y * speed,
        life: 0,
        ttl: 980 + Math.random() * 520,
        length: (140 + Math.random() * 130) * scale,
        width: (1.4 + Math.random() * 1.4) * scale,
      });
    };

    const update = (deltaMs: number, now: number) => {
      velocity.tx *= 0.96;
      velocity.ty *= 0.96;
      velocity.x += (velocity.tx - velocity.x) * 0.8;
      velocity.y += (velocity.ty - velocity.y) * 0.8;

      stars.forEach((star) => {
        star.x += velocity.x * star.z;
        star.y += velocity.y * star.z;
        star.x += (star.x - width / 2) * velocity.z * star.z;
        star.y += (star.y - height / 2) * velocity.z * star.z;
        star.z += velocity.z;

        if (
          star.x < -OVERFLOW_THRESHOLD ||
          star.x > width + OVERFLOW_THRESHOLD ||
          star.y < -OVERFLOW_THRESHOLD ||
          star.y > height + OVERFLOW_THRESHOLD
        ) {
          recycleStar(star);
        }
      });

      if (
        now - lastShooterAt > SHOOTING_STAR_PERIOD ||
        shootingStars.length < MIN_ACTIVE_SHOOTING_STARS
      ) {
        spawnShootingStar();
        lastShooterAt = now;
      }

      for (let i = shootingStars.length - 1; i >= 0; i--) {
        const shooter = shootingStars[i];
        shooter.life += deltaMs;
        shooter.x += shooter.vx * (deltaMs / 16.67);
        shooter.y += shooter.vy * (deltaMs / 16.67);

        if (
          shooter.life > shooter.ttl ||
          shooter.x < -shooter.length ||
          shooter.x > width + shooter.length ||
          shooter.y < -shooter.length ||
          shooter.y > height + shooter.length
        ) {
          shootingStars.splice(i, 1);
        }
      }
    };

    const render = () => {
      context.clearRect(0, 0, width, height);
      context.save();
      context.globalCompositeOperation = "lighter";

      stars.forEach((star) => {
        context.beginPath();
        context.lineCap = "round";
        context.lineWidth = STAR_SIZE * star.z * scale;
        context.globalAlpha = 0.35 + 0.65 * Math.random();
        context.strokeStyle = STAR_COLOR;
        context.moveTo(star.x, star.y);

        let tailX = velocity.x * 2;
        let tailY = velocity.y * 2;
        if (Math.abs(tailX) < 0.1) tailX = 0.5;
        if (Math.abs(tailY) < 0.1) tailY = 0.5;
        context.lineTo(star.x + tailX, star.y + tailY);
        context.stroke();
      });

      shootingStars.forEach((shooter) => {
        const progress = Math.min(shooter.life / shooter.ttl, 1);
        const fade = Math.sin(progress * Math.PI);
        const angle = Math.atan2(shooter.vy, shooter.vx);
        const tailX = Math.cos(angle) * shooter.length;
        const tailY = Math.sin(angle) * shooter.length;
        const gradient = context.createLinearGradient(
          shooter.x - tailX,
          shooter.y - tailY,
          shooter.x,
          shooter.y,
        );

        gradient.addColorStop(0, "rgba(255, 247, 199, 0)");
        gradient.addColorStop(0.55, `rgba(255, 220, 130, ${0.42 * fade})`);
        gradient.addColorStop(1, `rgba(255, 255, 255, ${fade})`);

        context.beginPath();
        context.lineCap = "round";
        context.lineWidth = shooter.width;
        context.globalAlpha = 1;
        context.strokeStyle = gradient;
        context.moveTo(shooter.x - tailX, shooter.y - tailY);
        context.lineTo(shooter.x, shooter.y);
        context.stroke();
      });

      context.restore();
    };

    const step = (now: number) => {
      if (!isVisible || isReducedMotion) {
        rafId = 0;
        return;
      }

      const deltaMs = lastFrameTime ? Math.min(now - lastFrameTime, 48) : 16.67;
      lastFrameTime = now;
      update(deltaMs, now);
      render();
      rafId = requestAnimationFrame(step);
    };

    const start = () => {
      if (rafId || isReducedMotion) return;
      lastFrameTime = 0;
      lastShooterAt = 0;
      spawnShootingStar();
      spawnShootingStar();
      rafId = requestAnimationFrame(step);
    };

    const stop = () => {
      if (!rafId) return;
      cancelAnimationFrame(rafId);
      rafId = 0;
    };

    const movePointer = (x: number, y: number) => {
      if (typeof pointerX === "number" && typeof pointerY === "number") {
        const ox = x - pointerX;
        const oy = y - pointerY;
        velocity.tx += (ox / (16 * scale)) * (touchInput ? 1 : -1);
        velocity.ty += (oy / (16 * scale)) * (touchInput ? 1 : -1);
      }

      pointerX = x;
      pointerY = y;
    };

    const onPointerMove = (event: PointerEvent) => {
      if (!isVisible) return;
      touchInput = event.pointerType === "touch";
      movePointer(event.clientX, event.clientY);
    };

    const onPointerLeave = () => {
      pointerX = null;
      pointerY = null;
    };

    const onResize = () => {
      resize();
      render();
    };

    const motionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
    const onMotionChange = () => {
      isReducedMotion = motionQuery.matches;
      if (isReducedMotion) {
        stop();
        context.clearRect(0, 0, width, height);
      } else if (isVisible) {
        start();
      }
    };

    const observer = new IntersectionObserver(
      (entries) => {
        isVisible = entries.some((entry) => entry.isIntersecting);
        if (isVisible) {
          resize();
          start();
        } else {
          stop();
        }
      },
      { rootMargin: "120px 0px", threshold: 0.01 },
    );

    resize();
    render();
    observer.observe(host);
    window.addEventListener("resize", onResize, { passive: true });
    window.addEventListener("pointermove", onPointerMove, { passive: true });
    document.addEventListener("pointerleave", onPointerLeave, {
      passive: true,
    });
    motionQuery.addEventListener("change", onMotionChange);

    const cleanup = () => {
      stop();
      observer.disconnect();
      window.removeEventListener("resize", onResize);
      window.removeEventListener("pointermove", onPointerMove);
      document.removeEventListener("pointerleave", onPointerLeave);
      motionQuery.removeEventListener("change", onMotionChange);
      canvas.dataset.footerStarInit = "";
    };

    window.addEventListener("pagehide", cleanup, { once: true });
    document.addEventListener("astro:before-swap", cleanup, { once: true });
  };

  const initFooterStars = () => {
    document
      .querySelectorAll<HTMLCanvasElement>("[data-footer-star-canvas]")
      .forEach(initFooterStarCanvas);
  };

  let footerClampRafId = 0;

  const clampScrollToFooterEnd = () => {
    footerClampRafId = 0;

    const footer = document.querySelector<HTMLElement>("footer#footer");
    const scrollRoot = document.scrollingElement || document.documentElement;
    if (!footer || !scrollRoot) return;

    const footerBottom = footer.getBoundingClientRect().bottom + window.scrollY;
    const maxScrollTop = Math.max(
      0,
      Math.ceil(footerBottom - window.innerHeight),
    );

    if (scrollRoot.scrollTop > maxScrollTop) {
      scrollRoot.scrollTop = maxScrollTop;
    }
  };

  const queueFooterClamp = () => {
    if (footerClampRafId) return;
    footerClampRafId = requestAnimationFrame(clampScrollToFooterEnd);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initFooterStars);
  } else {
    initFooterStars();
  }

  window.addEventListener("app:variants-mounted", initFooterStars);
  window.addEventListener("app:variants-mounted", queueFooterClamp);
  window.addEventListener("scroll", queueFooterClamp, { passive: true });
  window.addEventListener("resize", queueFooterClamp, { passive: true });
  window.addEventListener("orientationchange", queueFooterClamp, {
    passive: true,
  });
</script>

