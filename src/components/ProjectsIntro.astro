<section
  id="projects-intro"
  class="projects-intro-section w-full flex items-center justify-center"
>
  <div
    class="w-full flex justify-start reveal-text-container font-polysans"
  >
    <p class="projects-intro-copy">
      <span
        class="text-[#F95F4A] font-light uppercase split-text"
        >At ACM VIT, we conduct structured project cycles throughout the year to
        foster innovation, hands-on learning, and creative problem-solving.
      </span><span
        class="text-white font-light uppercase split-text"
        >These project cycles reflect the diversity of technologies explored
        within the chapter and encourage members to push boundaries, experiment
        boldly, and grow through real-world application. Through these projects,
        we also aim to create meaningful community impact by building solutions
        that address real-world challenges and contribute beyond the campus.</span
      >
    </p>
  </div>
</section>

<style>
  .projects-intro-section {
    min-height: 100svh;
    box-sizing: border-box;
    padding: clamp(5rem, 12vw, 8rem) clamp(1rem, 5vw, 1.5rem);
    overflow: hidden;
  }

  .font-polysans {
    font-family: "PolySans Trial", sans-serif;
  }

  .reveal-text-container {
    max-width: min(64rem, 100%);
    transform-origin: 0% 50%;
  }

  .projects-intro-copy {
    max-width: 100%;
    margin: 0;
    font-size: clamp(1.125rem, 2.1vw, 1.5rem);
    line-height: 1.5;
    overflow-wrap: normal;
    word-break: normal;
  }

  @media (max-width: 768px) {
    .projects-intro-section {
      align-items: center;
      min-height: 100svh;
      padding-top: clamp(5.5rem, 14svh, 7rem);
      padding-bottom: clamp(5.5rem, 14svh, 7rem);
    }

    .reveal-text-container {
      max-width: min(34rem, 92vw);
      transform-origin: 50% 50%;
    }

    .projects-intro-copy {
      font-size: clamp(0.98rem, 4.45vw, 1.18rem);
      line-height: 1.42;
    }
  }

  @media (max-width: 380px) {
    .projects-intro-copy {
      font-size: clamp(0.9rem, 4.25vw, 1rem);
      line-height: 1.38;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  const section = document.querySelector("#projects-intro");
  const container = document.querySelector(".reveal-text-container");

  if (container && section) {
    const splitTextElements = container.querySelectorAll(".split-text");

    // Split text into words for each span
    splitTextElements.forEach((element) => {
      const text = element.textContent || "";
      element.innerHTML = text
        .split(/(\s+)/)
        .map((word) => {
          if (word.match(/^\s+$/)) return word;
          return `<span class="inline-block word">${word}</span>`;
        })
        .join("");
    });
    if (typeof window !== "undefined") {
      const isMobileViewport = () =>
        window.matchMedia("(max-width: 768px)").matches;
      const allWords = Array.from(
        container.querySelectorAll<HTMLElement>(".word")
      );

      gsap.set(allWords, { opacity: 0.1, willChange: "opacity" });
      gsap.set(container, {
        rotate: isMobileViewport() ? 1.25 : 3,
        force3D: true,
        willChange: "transform",
      });

      const getRevealProgress = () => {
        const rect = section.getBoundingClientRect();
        const viewportHeight =
          window.visualViewport?.height || window.innerHeight || 1;
        const start = viewportHeight * (isMobileViewport() ? 0.9 : 0.92);
        const end = viewportHeight * (isMobileViewport() ? 0.26 : 0.5);
        const distance = Math.max(1, rect.height + start - end);

        return gsap.utils.clamp(0, 1, (start - rect.top) / distance);
      };

      const updateReveal = () => {
        const progress = getRevealProgress();
        const rotate = gsap.utils.interpolate(
          isMobileViewport() ? 1.25 : 3,
          0,
          progress
        );
        gsap.set(container, { rotate });

        const revealWindow = 0.34;
        allWords.forEach((word, index) => {
          const wordProgress =
            allWords.length <= 1 ? 1 : index / (allWords.length - 1);
          const localProgress = gsap.utils.clamp(
            0,
            1,
            (progress - wordProgress * (1 - revealWindow)) / revealWindow
          );
          gsap.set(word, {
            opacity: gsap.utils.interpolate(0.1, 1, localProgress),
          });
        });
      };

      let revealRafId = 0;
      const queueRevealUpdate = () => {
        if (revealRafId) return;
        revealRafId = requestAnimationFrame(() => {
          revealRafId = 0;
          updateReveal();
        });
      };

      updateReveal();

      window.addEventListener("scroll", queueRevealUpdate, { passive: true });
      document.body.addEventListener("scroll", queueRevealUpdate, {
        passive: true,
      });
      window.addEventListener("resize", queueRevealUpdate, { passive: true });
      window.addEventListener("orientationchange", queueRevealUpdate, {
        passive: true,
      });
      window.addEventListener("app:variants-mounted", queueRevealUpdate);
      window.visualViewport?.addEventListener("scroll", queueRevealUpdate, {
        passive: true,
      });
      window.visualViewport?.addEventListener("resize", queueRevealUpdate, {
        passive: true,
      });

      const cleanupReveal = () => {
        if (revealRafId) {
          cancelAnimationFrame(revealRafId);
          revealRafId = 0;
        }

        window.removeEventListener("scroll", queueRevealUpdate);
        document.body.removeEventListener("scroll", queueRevealUpdate);
        window.removeEventListener("resize", queueRevealUpdate);
        window.removeEventListener("orientationchange", queueRevealUpdate);
        window.removeEventListener("app:variants-mounted", queueRevealUpdate);
        window.visualViewport?.removeEventListener(
          "scroll",
          queueRevealUpdate
        );
        window.visualViewport?.removeEventListener(
          "resize",
          queueRevealUpdate
        );
        document.removeEventListener("astro:before-swap", cleanupReveal);
      };

      document.addEventListener("astro:before-swap", cleanupReveal, {
        once: true,
      });
    }
  }
  // Container Animation (Rotation)
</script>
