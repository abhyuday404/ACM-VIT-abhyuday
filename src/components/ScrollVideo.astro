---
import { getAssetUrl } from "../utils/cdn";

interface Props {
    webmSrc?: string;
    mp4Src?: string;
    startTime?: number;
    endTime?: number;
}

const {
    webmSrc = "/ACMWebsiteVid.webm",
    mp4Src = "/ACMWebsiteVid.mp4",
    startTime = 0,
    endTime = undefined,
} = Astro.props;

const normalizedWebmSrc = webmSrc.startsWith("/") ? webmSrc : `/${webmSrc}`;
const normalizedMp4Src = mp4Src.startsWith("/") ? mp4Src : `/${mp4Src}`;
---

<div class="scroll-video-container" data-scroll-video-container>
    <video
        class="scroll-video"
        data-scroll-video
        data-start-time={startTime}
        data-end-time={endTime ?? ""}
        muted
        playsinline
        preload="auto"
    >
        <!-- H.264 is the primary source so every device gets the frame-dense encode. -->
        <source src={getAssetUrl(normalizedMp4Src)} type="video/mp4" />
        <source src={getAssetUrl(normalizedWebmSrc)} type="video/webm" />
    </video>

    <div class="scroll-video-overlay" data-scroll-video-overlay></div>

    <div class="scroll-video-content" data-scroll-video-content>
        <slot />
    </div>
</div>

<style>
    .scroll-video-container {
        position: relative;
        width: 100%;
    }

    .scroll-video {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        object-fit: cover;
        z-index: -1;
        pointer-events: none;
        opacity: 0;
        transform: translateZ(0);
        backface-visibility: hidden;
        will-change: opacity, transform;
        transition: opacity 0.6s ease-out;
    }

    .scroll-video.visible {
        opacity: 1;
    }

    .scroll-video-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: black;
        opacity: 0;
        z-index: -1;
        pointer-events: none;
        transition: opacity 0.6s ease-out;
    }

    .scroll-video-overlay.visible {
        opacity: 0.6;
    }

    .scroll-video-content {
        position: relative;
        z-index: 1;
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    function initScrollVideo() {
        const container = document.querySelector(
            "[data-scroll-video-container]",
        ) as HTMLElement;
        const video = document.querySelector(
            "[data-scroll-video]",
        ) as HTMLVideoElement;
        const overlay = document.querySelector(
            "[data-scroll-video-overlay]",
        ) as HTMLElement;

        if (!container || !video) {
            return;
        }

        if (video.dataset.scrollInit === "true") {
            return;
        }
        video.dataset.scrollInit = "true";

        const startTime = parseFloat(video.dataset.startTime || "0");
        const sourceFrameRate = 60;
        const frameDuration = 1 / sourceFrameRate;
        const minStep = frameDuration / 4;
        const desktopSmoothQuery = window.matchMedia(
            "(min-width: 769px) and (pointer: fine)",
        );
        let scrubTrigger: any = null;
        let visibilityTrigger: any = null;
        let targetTime = startTime;
        let renderedTime = startTime;
        let rafId = 0;
        let lastFrameAt = 0;
        let useSmoothDesktopScrub = desktopSmoothQuery.matches;
        let removeDesktopModeListener: (() => void) | null = null;

        const removeDesktopModeQueryListener = () => {
            removeDesktopModeListener?.();
            removeDesktopModeListener = null;
        };

        const addDesktopModeQueryListener = (handler: () => void) => {
            removeDesktopModeQueryListener();

            desktopSmoothQuery.addEventListener("change", handler);
            removeDesktopModeListener = () => {
                desktopSmoothQuery.removeEventListener("change", handler);
            };
        };

        const cleanupScrollVideo = () => {
            removeDesktopModeQueryListener();

            if (rafId) {
                cancelAnimationFrame(rafId);
                rafId = 0;
            }

            scrubTrigger?.kill();
            scrubTrigger = null;
            visibilityTrigger?.kill();
            visibilityTrigger = null;
            video.dataset.scrollInit = "";

            window.removeEventListener("pagehide", cleanupScrollVideo);
            document.removeEventListener("astro:before-swap", cleanupScrollVideo);
        };

        const setupScrollTrigger = () => {
            const videoDuration = video.duration;
            if (!videoDuration || isNaN(videoDuration) || videoDuration === Infinity) {
                return;
            }

            // We have a valid duration! Clean up all listeners to avoid multiple setups.
            video.removeEventListener("loadedmetadata", setupScrollTrigger);
            video.removeEventListener("durationchange", setupScrollTrigger);
            video.removeEventListener("canplay", setupScrollTrigger);
            video.removeEventListener("canplaythrough", setupScrollTrigger);
            video.removeEventListener("loadeddata", setupScrollTrigger);

            const requestedEndTime = video.dataset.endTime
                ? parseFloat(video.dataset.endTime)
                : videoDuration;
            const endTime = Math.max(startTime + minStep, requestedEndTime);
            const playDuration = Math.max(minStep, endTime - startTime);

            video.pause();

            removeDesktopModeQueryListener();
            if (rafId) {
                cancelAnimationFrame(rafId);
                rafId = 0;
            }
            lastFrameAt = 0;
            scrubTrigger?.kill();
            scrubTrigger = null;
            visibilityTrigger?.kill();
            visibilityTrigger = null;

            const snapToSourceFrame = (time: number) => {
                const clamped = Math.max(startTime, Math.min(endTime, time));
                const frameIndex = Math.round((clamped - startTime) / frameDuration);
                return Math.max(
                    startTime,
                    Math.min(endTime, startTime + frameIndex * frameDuration),
                );
            };

            // Attempt to unlock the video decoder for frame-exact seeking in Safari and mobile browsers
            const unlockVideo = async () => {
                try {
                    await video.play();
                    video.pause();
                } catch (e) {
                    // Safe to ignore if blocked by autoplay policies
                }
            };
            unlockVideo();

            const commitVideoTime = (nextTime: number) => {
                const clamped = snapToSourceFrame(nextTime);
                if (Math.abs(video.currentTime - clamped) <= minStep) return;

                try {
                    video.currentTime = clamped;
                } catch {
                    video.currentTime = clamped;
                }
            };

            const renderSmoothedFrame = (now: number) => {
                rafId = 0;

                if (!useSmoothDesktopScrub) {
                    renderedTime = targetTime;
                    commitVideoTime(renderedTime);
                    lastFrameAt = 0;
                    return;
                }

                const delta = lastFrameAt
                    ? Math.min((now - lastFrameAt) / 1000, 0.05)
                    : 1 / 60;
                lastFrameAt = now;

                const diff = targetTime - renderedTime;
                if (Math.abs(diff) <= minStep) {
                    renderedTime = targetTime;
                    commitVideoTime(renderedTime);
                    lastFrameAt = 0;
                    return;
                }

                const ease = 1 - Math.exp(-delta / 0.08);
                const maxStep = frameDuration;
                const easedStep = diff * ease;
                const step =
                    Math.sign(diff) *
                    Math.min(Math.abs(easedStep), Math.abs(diff), maxStep);

                renderedTime += step;
                commitVideoTime(renderedTime);

                if (Math.abs(targetTime - renderedTime) > minStep && !rafId) {
                    rafId = requestAnimationFrame(renderSmoothedFrame);
                } else {
                    lastFrameAt = 0;
                }
            };

            const scheduleVideoRender = () => {
                if (rafId) return;
                rafId = requestAnimationFrame(renderSmoothedFrame);
            };

            const applyVideoTime = (nextTime: number, force = false) => {
                targetTime = Math.max(startTime, Math.min(endTime, nextTime));

                if (force || !useSmoothDesktopScrub) {
                    renderedTime = targetTime;
                    commitVideoTime(renderedTime);
                    lastFrameAt = 0;
                    return;
                }

                scheduleVideoRender();
            };

            const handleDesktopModeChange = () => {
                useSmoothDesktopScrub = desktopSmoothQuery.matches;
                renderedTime = video.currentTime || targetTime;
                scheduleVideoRender();
            };

            addDesktopModeQueryListener(handleDesktopModeChange);

            applyVideoTime(startTime, true);

            scrubTrigger = ScrollTrigger.create({
                trigger: container,
                start: "top top",
                end: "bottom bottom",
                scrub: true,
                invalidateOnRefresh: true,
                onUpdate: (self) => {
                    applyVideoTime(startTime + self.progress * playDuration);
                },
                onRefresh: (self) => {
                    applyVideoTime(
                        startTime + self.progress * playDuration,
                        true,
                    );
                },
            });

            visibilityTrigger = ScrollTrigger.create({
                trigger: container,
                start: "top 90%",
                end: "bottom 60%",
                onEnter: () => {
                    video.classList.add("visible");
                    overlay?.classList.add("visible");
                    document.body.classList.add("scroll-video-active");
                },
                onLeave: () => {
                    video.classList.remove("visible");
                    overlay?.classList.remove("visible");
                    document.body.classList.remove("scroll-video-active");
                },
                onEnterBack: () => {
                    video.classList.add("visible");
                    overlay?.classList.add("visible");
                    document.body.classList.add("scroll-video-active");
                },
                onLeaveBack: () => {
                    video.classList.remove("visible");
                    overlay?.classList.remove("visible");
                    document.body.classList.remove("scroll-video-active");
                },
            });

            window.requestAnimationFrame(() => ScrollTrigger.refresh());
        };

        // Register multiple event listeners to guarantee duration is detected
        video.addEventListener("loadedmetadata", setupScrollTrigger);
        video.addEventListener("durationchange", setupScrollTrigger);
        video.addEventListener("canplay", setupScrollTrigger);
        video.addEventListener("canplaythrough", setupScrollTrigger);
        video.addEventListener("loadeddata", setupScrollTrigger);

        // Check immediately in case video metadata/duration is already fully ready
        if (video.readyState >= 1) {
            setupScrollTrigger();
        }

        window.addEventListener("pagehide", cleanupScrollVideo, { once: true });
        document.addEventListener("astro:before-swap", cleanupScrollVideo, {
            once: true,
        });

        video.pause();
        video.currentTime = startTime;
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initScrollVideo);
    } else {
        initScrollVideo();
    }
</script>
