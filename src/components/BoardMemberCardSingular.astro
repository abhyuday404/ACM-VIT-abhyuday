---
interface Props {
  title: string;
  fullName: string;
  position: string;
  imageUrl: string;
  linkedinUrl?: string;
  googleScholarUrl?: string;
  githubUrl?: string;
  isW?: boolean;
  preloadImage?: boolean;
}

const {
  title,
  fullName,
  position,
  imageUrl,
  linkedinUrl,
  googleScholarUrl,
  githubUrl,
  isW,
  preloadImage = false,
} = Astro.props;

import { getAssetUrl } from "../utils/cdn";

const displayName = `${title?.trim() ? `${title.trim()} ` : ""}${fullName.trim()}`;
const isFaculty = position.toLowerCase().includes("faculty");
---

<div
  class="board-member-card relative w-full aspect-[1.6] rounded-lg bg-white overflow-hidden flex items-end justify-center"
  data-faculty={isFaculty}
>
  <!-- Background Pattern -->
  <div
    class="absolute inset-0 pointer-events-none opacity-50 z-0"
    style={`background-image: url('${getAssetUrl("/noise.webp")}'); background-size: cover;`}
  >
  </div>
  <div
    class="w-[97%] h-[96.5%] flex justify-center items-center absolute z-20 pointer-events-none"
  >
    <img
      src={isW
        ? getAssetUrl("/casette-layout-pink.webp")
        : getAssetUrl("/casette-layout-orange.webp")}
      alt="Background Pattern"
      class="absolute w-full h-full object-cover"
      loading="lazy"
      decoding="async"
    />
  </div>

  <div
    class="w-full flex justify-center items-center z-20 h-[20%] pb-1 absolute bottom-0"
  >
    <img
      src={getAssetUrl("/acm-logo-black.webp")}
      alt="ACM-VIT Logo"
      class="h-full object-cover"
      loading="lazy"
      decoding="async"
    />
  </div>

  <!-- Member Info -->
  <div class="flex items-center w-full h-full text-center z-10">
    <div class="h-full w-2/5 flex items-end overflow-hidden">
      <img
        src={imageUrl}
        alt={fullName}
        class="h-full w-full object-cover object-top"
        loading="lazy"
        decoding="async"
        data-board-preload={preloadImage}
        data-preloader-ignore={preloadImage}
      />
    </div>

    <div
      class="board-card-copy w-3/5 min-w-0 z-20 text-left flex flex-col justify-center mb-10 gap-1.5 pl-5 pr-4 sm:pl-6"
    >
      <div class="">
        <h3
          style="font-family: 'PolySans Bold';"
          class="board-card-name text-gray-900 m-0"
        >
          {displayName}
        </h3>
        <p
          style="font-family: PolySans Slim;"
          class={!isW
            ? "board-card-role text-primary-orange m-0"
            : "board-card-role text-[#FF007A] m-0"}
        >
          {position}
        </p>
      </div>

      <!-- Social Links -->
      <div class="board-card-social flex justify-center gap-3 mt-2">
        {
          linkedinUrl && (
            <a
              href={linkedinUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:cursor-pointer"
            >
              <img
                src={
                  isW
                    ? getAssetUrl("/linkedin-pink.webp")
                    : getAssetUrl("/linkedin-orange.webp")
                }
                alt="LinkedIn"
                class="board-card-icon"
                loading="lazy"
                decoding="async"
              />
            </a>
          )
        }

        {
          googleScholarUrl && (
            <a
              href={googleScholarUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:cursor-pointer"
            >
              <img
                src={
                  isW
                    ? getAssetUrl("/google-scholar-pink.webp")
                    : getAssetUrl("/google-scholar-orange.webp")
                }
                alt="Google Scholar"
                class="board-card-icon"
                loading="lazy"
                decoding="async"
              />
            </a>
          )
        }

        {
          githubUrl && (
            <a
              href={githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:cursor-pointer"
            >
              <img
                src={
                  isW
                    ? getAssetUrl("/github-pink.webp")
                    : getAssetUrl("/github-orange.webp")
                }
                alt="GitHub"
                class="board-card-icon"
                loading="lazy"
                decoding="async"
              />
            </a>
          )
        }
      </div>
    </div>
  </div>
</div>

<style>
  .board-card-name {
    display: block;
    max-width: 100%;
    overflow-wrap: anywhere;
    font-size: clamp(0.82rem, 2.9vw, 1.16rem);
    line-height: 1.08;
  }

  .board-card-role {
    display: block;
    max-width: 100%;
    overflow-wrap: anywhere;
    font-size: clamp(0.72rem, 2.25vw, 0.98rem);
    line-height: 1.16;
  }

  .board-card-icon {
    width: clamp(1.1rem, 4.8vw, 1.75rem);
    height: clamp(1.1rem, 4.8vw, 1.75rem);
    object-fit: contain;
  }

  .board-member-card[data-faculty="true"] .board-card-copy {
    padding-left: clamp(0.85rem, 3vw, 1.25rem);
    padding-right: clamp(0.85rem, 3vw, 1.25rem);
    margin-bottom: clamp(1.35rem, 5vw, 2.25rem);
  }

  .board-member-card[data-faculty="true"] .board-card-name {
    font-size: clamp(0.76rem, 2.55vw, 1.02rem);
    line-height: 1.04;
  }

  .board-member-card[data-faculty="true"] .board-card-role {
    font-size: clamp(0.68rem, 2.2vw, 0.9rem);
  }

  .board-member-card[data-faculty="true"] .board-card-social {
    gap: clamp(0.4rem, 1.8vw, 0.75rem);
    margin-top: clamp(0.2rem, 1vw, 0.5rem);
  }
</style>
