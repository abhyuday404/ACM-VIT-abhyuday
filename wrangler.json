{
  "name": "acmvit-website",
  "compatibility_date": "2026-01-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "dist/_worker.js/index.js",
  "assets": {
    "directory": "dist"
  },
  "vars": {
    "PUBLIC_CDN_URL": "https://acmvitin.s3.ap-south-1.amazonaws.com"
  },
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  }
}